{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix quivro_web",
  "buildCommand": "npm run build --prefix quivro_web",
  "outputDirectory": "quivro_web/dist/web/browser",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
